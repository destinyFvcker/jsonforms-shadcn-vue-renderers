{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "declaration": true,
    "declarationMap": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "types": [
      "vite/client"
    ],
    "baseUrl": "../..",
    "paths": {
      "@/*": [
        "app/*"
      ],
      "~/*": [
        "app/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "../../app/components/renders/**/*.ts",
    "../../app/components/renders/**/*.vue",
    "../../app/components/ui/**/*.ts",
    "../../app/components/ui/**/*.vue",
    "../../app/lib/utils.ts"
  ]
}
